# tally-ho environment overrides for docker compose.
#
#   cp .env.example .env      # then edit the values below
#
# Every setting has a default (shown as the value after ':-' in docker-compose.yml), 
# so uncomment only the ones you want to change. App behaviour lives in ./data/config.toml
# this file only covers the container's host-side wiring.

# --- File ownership -----------------------------------------------------------
# Run the container as this uid:gid. Must own the bind-mount dirs below, or the
# app can't write to them. Set to your own account: run `id -u` / `id -g`.
# Defaults to the image's tallyho user (10001) if left unset.
PUID=1000
PGID=1000

# --- Timezone -----------------------------------------------------------------
# IANA zone name for human-facing times (dashboard clock + ntfy ETAs).
# e.g. America/New_York, Europe/London, UTC. Defaults to America/Los_Angeles.
#TZ=America/Los_Angeles

# --- Published port -----------------------------------------------------------
# Host port for the dashboard (container always listens on 8080). Defaults 8080.
#TALLYHO_PORT=8080

# --- Image --------------------------------------------------------------------
# Builds locally by default. To run the CI-published image instead, uncomment
# this and `docker compose pull`. Defaults to the locally built tally-ho:local.
#TALLYHO_IMAGE=ghcr.io/albodin/tally-ho:latest

# --- Bind-mount paths ---------------------------------------------------------
# Where the container's data lives on the host. Each dir must be owned by the
# PUID:PGID above. Defaults are these ./ paths, relative to this file.
#TALLYHO_DATA_DIR=./data   # SQLite DB + heartbeat
#TALLYHO_GFS_DIR=./gfs     # GFS wind cache
#TALLYHO_HRRR_DIR=./hrrr   # HRRR wind cache (CONUS only)
#TALLYHO_DEM_DIR=./dem     # Copernicus GLO-30 terrain tiles (auto-downloaded)
