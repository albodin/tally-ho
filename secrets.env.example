# ntfy bearer tokens
#
#   cp secrets.env.example secrets.env      # then add your real tokens
#
# A subscriber's `token-ref` in config names the variable to read (never the
# token itself), so `token-ref = NTFY_HOME` sends using the value of $NTFY_HOME.
# Add one line per named topic. Loaded by docker compose (env_file)

NTFY_HOME=tk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
